{
  "name": "guildframe-site",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "build:pages": "node scripts/launch-preflight.mjs --strict && npm run build && node scripts/optimize-pages-output.mjs",
    "build:pages:local": "npm run build && node scripts/optimize-pages-output.mjs",
    "preflight": "node scripts/launch-preflight.mjs",
    "preflight:strict": "node scripts/launch-preflight.mjs --strict",
    "test": "NEXT_PUBLIC_SITE_URL=http://localhost:3000 NEXT_PUBLIC_GA_MEASUREMENT_ID=G-TEST123456 npm run build:pages:local && node --test tests/static-output.test.mjs",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3"
  },
  "type": "module"
}
